      "link": null,
      "locked": false,
      "text": "{{SOLUTION}}\n\nn = int(input())\nnums = list(map(int, input().split()))\ntarget = int(input())\n\nanswer = two_sum(nums, target)\nanswer = sorted(answer)\nprint(answer[0], answer[1])\n",
      "fontSize": 17.374945746527786,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
