      "updated": 1783616264831,
      "link": null,
      "locked": false,
      "text": "def two_sum(nums: list[int], target: \nint) -> list[int]:\n    seen = {}\n    for i, value in enumerate(nums):\n        needed = target - value\n        if needed in seen:\n            return [seen[needed], i]\n        seen[value] = i\n    return []\n",
      "fontSize": 20,
      "fontFamily": 3,
      "textAlign": "center",
      "verticalAlign": "middle",
      "baseline": 236,
      "containerId": "8PW4N0Vos3qaMYAiWKfPt",
      "originalText": "def two_sum(nums: list[int], target: int) -> list[int]:\n    seen = {}\n    for i, value in enumerate(nums):\n        needed = target - value\n        if needed in seen:\n            return [seen[needed], i]\n        seen[value] = i\n    return []\n",
      "lineHeight": 1.2
    },
